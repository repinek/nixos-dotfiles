_: {
  wayland.windowManager.hyprland.settings.input = {
    # Switch US / RU layout with SHIFT + ALT
    kb_layout = "us,ru";
    kb_options = "grp:alt_shift_toggle";

    follow_mouse = 1;

    accel_profile = "flat"; # raw input
    force_no_accel = true; # no accel: sens 1:1
    sensitivity = 0;
  };
}
